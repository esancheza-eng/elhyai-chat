# ============================================================
# ElhyAi Campaigns — Variables de Entorno
# Copia este archivo como .env y completa tus datos
# ============================================================

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3001

# ── WhatsApp Cloud API (Meta) ────────────────────────────────
# Obtener en: developers.facebook.com → Tu App → WhatsApp → Configuración API
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PHONE_NUMBER_ID=1234567890123456

# Token para verificar el webhook (invéntate una palabra secreta)
VERIFY_TOKEN=elhyai_webhook_secret_2025

# ── WhatsApp Business Account ID (opcional, para estadísticas) ──
WABA_ID=

# ── Entorno ──────────────────────────────────────────────────
NODE_ENV=production
